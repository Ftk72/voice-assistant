# Secrets locaux — copier en `.env` (non versionné) et générer les valeurs :
#   cp .env.example .env
#   sed -i "s/changez-moi.*/$(openssl rand -hex 32)/" ... ou éditer à la main.

# Clé de session SearXNG (prime sur server.secret_key de searxng/settings.yml).
SEARXNG_SECRET=changez-moi-openssl-rand-hex-32

# Jeton partagé du Pont hôte : même valeur au lancement du Pont (HOST_BRIDGE_TOKEN)
# et dans le conteneur time (le compose la lui passe). Voir ADR 0008, addendum.
HOST_BRIDGE_TOKEN=changez-moi-openssl-rand-hex-32

# Mot de passe Neo4j (utilisateur `neo4j`), lu par les services neo4j et memory.
NEO4J_PASSWORD=changez-moi-openssl-rand-hex-16
